# Cesta k MuseScore 4 binárce; pokud nenastaveno, render.py si ji najde sám.
# macOS default: /Applications/MuseScore 4.app/Contents/MacOS/mscore
# Linux default: /usr/bin/mscore  nebo  /usr/bin/musescore4
MUSESCORE_PATH=

# Limit délky vstupního audia v sekundách (default 60).
MAX_AUDIO_SECONDS=60

# --- Volitelné: vokál izolace ---
# roformer (default) | demucs
SEPARATION_BACKEND=roformer

# --- Volitelné: alternativní transkripce ---
# basic_pitch (default) | aria_amt (jen kategorie klavir; ostatní fallback na basic_pitch)
TRANSCRIPTION_BACKEND=basic_pitch

# --- Volitelné: LLM cleanup přes Claude API ---
# Aktivuje LLM post-process (oprava taktu, klíče, drop notes).
LLM_CLEANUP=0

# Auth — vyber JEDNU cestu:
#
# A) Microsoft Foundry s API klíčem (firemní billing přes Azure subscription):
# ANTHROPIC_FOUNDRY_RESOURCE=<vase-foundry-resource-jmeno>
# ANTHROPIC_FOUNDRY_API_KEY=<klic-z-foundry-portalu>
#
# B) Microsoft Foundry s Entra ID (managed identity / DefaultAzureCredential):
#    Pro produkční deploy v Azure — `azure login` lokálně, role "Cognitive Services User".
# ANTHROPIC_FOUNDRY_RESOURCE=<vase-foundry-resource-jmeno>
# (žádný API key — SDK použije DefaultAzureCredential)
#
# C) First-party Anthropic API (osobní účet):
# ANTHROPIC_API_KEY=sk-ant-...
